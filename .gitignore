# Binaries
bin/
cache/
.cache/

# Python cache files
**/__pycache__/
__pycache__/**

# Virtual environments
.venv

# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
bin/*
Dockerfile.cross
# Test binary, built with `go test -c`
*.test
# Output of the go coverage tool, specifically when used with LiteIDE
*.out
# Go workspace file
go.work
go.work.sum
# Kubernetes Generated files - skip generated files, except for vendored files
!vendor/**/zz_generated.*
# editor and IDE paraphernalia
.idea
.vscode
*.swp
*.swo
*~

# generated docs
site

# Auto-generated proposal files (originals in docs/proposals/)
site-src/proposals/*.md
!site-src/proposals/overview.md
!site-src/proposals/README.md

# Auto-generated landing pages
site-src/proposals/landing/*.md
!site-src/proposals/landing/.pages
